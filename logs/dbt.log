order_revenue as (
    select
        order_id,
        sum(revenue) as order_total_revenue
    from orders_items
    group by order_id
),

final as (
    select
        oi.order_id,
        oi.customer_id,
        oi.employee_id,
        oi.product_id,
        oi.category_id,
        oi.shipper_id,
        oi.order_date,
