  create view "dev"."main"."int_employees_territories__dbt_tmp" as (
    with employees as (
    select * from "dev"."main"."stg_employees"
),

employee_territories as (
    select * from "dev"."main"."stg_employee_territories"
),

territories as (
    select * from "dev"."main"."stg_territories"
),

